# Scraper
CENTRIS_SEARCH_URL=https://www.centris.ca
HEADLESS=true
SCRAPER_TIMEOUT_MS=60000
SCRAPER_LOCALE=en-CA
SCRAPER_TIMEZONE=America/Toronto
SCRAPER_VIEWPORT_WIDTH=1440
SCRAPER_VIEWPORT_HEIGHT=900
SCRAPER_SLOW_MO_MS=0
BROWSER_CHANNEL=chrome

# Search crawling
SEARCH_PAGE_SIZE=20
MAX_SEARCH_PAGES=20
SEARCH_MAX_LISTINGS=500

# Detail page scraping
DETAIL_CONCURRENCY=3
REQUEST_DELAY_MS=400
PAGE_NAVIGATION_DELAY_MS=500
DETAIL_RECHECK_MODE=all
DETAIL_RECHECK_HOURS=24

# Run identification
RUN_ID_PREFIX=centris

# Google Sheets via Apps Script (optional — skip to scrape without writing)
GOOGLE_APPS_SCRIPT_URL=
GOOGLE_APPS_SCRIPT_KEY=

# Telegram (optional — set TELEGRAM_ENABLED=false to disable)
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=HTML
TELEGRAM_SEND_DELAY_MS=500
TELEGRAM_MAX_RETRIES=2
TELEGRAM_RETRY_DELAY_MS=1000

# Scheduler (used by npm run scheduler)
SCHEDULER_ENABLED=true
SCHEDULE_INTERVAL_MINUTES=30
SCHEDULE_RUN_ON_START=true

# Cross-process run lock
RUN_LOCK_ENABLED=true
RUN_LOCK_PATH=.runtime/centris-scraper.lock
RUN_LOCK_STALE_MINUTES=180

# Failure alerts (optional; uses TELEGRAM_CHAT_ID when TELEGRAM_ALERT_CHAT_ID is empty)
FAILURE_ALERTS_ENABLED=false
TELEGRAM_ALERT_CHAT_ID=
FAILURE_ALERT_COOLDOWN_MINUTES=60

# Persistent metrics
METRICS_ENABLED=true
METRICS_PATH=.runtime/metrics.json
METRICS_HISTORY_LIMIT=500
METRICS_FLUSH_MODE=per-run

# Persistent health report
HEALTH_REPORT_ENABLED=true
HEALTH_REPORT_PATH=.runtime/health.json

# Shared retry policy
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=500
RETRY_MAX_DELAY_MS=10000
RETRY_JITTER_RATIO=0.2
SEARCH_RETRY_MAX_ATTEMPTS=3
DETAIL_RETRY_MAX_ATTEMPTS=3
SHEET_RETRY_MAX_ATTEMPTS=3

# Centris request rate limits
RATE_LIMIT_ENABLED=true
SEARCH_REQUESTS_PER_MINUTE=20
DETAIL_REQUESTS_PER_MINUTE=30
RATE_LIMIT_BURST=3

# Persistent detail cache
# Flushed once atomically after the detail stage.
DETAIL_CACHE_ENABLED=true
DETAIL_CACHE_PATH=.runtime/detail-cache.json
DETAIL_CACHE_TTL_HOURS=24
DETAIL_CACHE_MAX_ENTRIES=5000
DETAIL_CACHE_SCHEMA_VERSION=1

# Diagnostic-only failure injection. Never enable in normal operation.
FAIL_TEST_ENABLED=false
FAIL_TEST_STAGE=none

# Local HTTP API (used by n8n workflow via POST /api/v1/runs/sentris)
API_PORT=8787
WORKFLOW_API_KEY=

# Proxy for Telegram API (optional — set if behind corporate firewall)
# If PowerShell Invoke-RestMethod can reach Telegram but Node.js fetch cannot,
# set the proxy that your system uses. Example for a local SOCKS5/HTTP proxy:
#   HTTPS_PROXY=http://127.0.0.1:10808
HTTPS_PROXY=
HTTP_PROXY=
